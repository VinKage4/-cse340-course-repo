<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h2><%= category.name %></h2>

    <h3>Service Projects</h3>

    <% if (projects.length > 0) { %>
        <ul>
            <% projects.forEach(project => { %>
                <li>
                    <a href="/project/<%= project.project_id %>">
                        <%= project.title %>
                    </a>
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>No service projects found for this category.</p>
    <% } %>
</main>

<%- include('partials/footer') %>